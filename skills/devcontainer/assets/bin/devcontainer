#!/usr/bin/env bash
# Devcontainer lifecycle for the {{PROJECT_NAME}} project. Works the same whether
# this checkout is the main clone or a linked git worktree — the worktree case is
# auto-detected (via `git rev-parse --git-common-dir`), no flag needed.
#
#   bin/devcontainer setup
#       One-time, per-clone prep, bundled into one idempotent command:
#         - check prerequisites (Docker running; note if the devcontainer CLI is
#           missing — `up` needs it)
#         - create the shared, external toolchain cache volumes (otherwise
#           `compose up` fails with "volume … could not be found")
#         - check the commit identity it will give the container: resolved on
#           the host from your GLOBAL git config (falling back to GIT_AUTHOR_* /
#           GIT_COMMITTER_* env vars) and, on `up`, written into the container's
#           OWN ~/.gitconfig.local — the repo's .git/config is left untouched.
#           If nothing is found, print how to set it.
#       Safe to re-run.
#
#   bin/devcontainer up [--name NAME] [--port PORT] [--recreate]
#       Ensure shared volumes exist, write .devcontainer/.env (project name,
#       port, the git-mount paths that make in-container commits work, and the
#       resolved commit identity for the container), and
#       bring the dev container up via the `devcontainer` CLI. Using the CLI (not
#       raw `docker compose up`) is what runs postCreateCommand (post_install.sh:
#       deps + DB) and stamps the locator labels that `devcontainer exec` needs.
#       Auto-recreates the container if its /workspace bind mount has gone stale
#       (e.g. the worktree was recreated). Pass --name to pin the Compose project
#       name to a stable handle (e.g. a worktree/branch handle) so up/exec/down
#       all target one stack; --recreate to force-recreate unconditionally.
#
#   bin/devcontainer down [--caches]
#       Tear down THIS checkout's stack: stop and remove its containers, default
#       network, and per-project volumes (shell history, agent/gh config, DB
#       data), and delete .devcontainer/.env. Shared toolchain caches are
#       preserved for other worktrees. Run this BEFORE deleting a worktree
#       directory. Pass --caches to ALSO remove the shared external caches — use
#       only when you're done with the whole project (other worktrees would have
#       to rebuild them).
#
#   bin/devcontainer status
#       Show stack status.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMPOSE_FILE="${ROOT}/.devcontainer/docker-compose.yml"
ENV_FILE="${ROOT}/.devcontainer/.env"
SHARED_VOLUMES=({{SHARED_VOLUMES}})

usage() {
  sed -n '2,/^set -euo/p' "$0" | sed '$d; s/^# \{0,1\}//'
}

# Docker must be installed AND running, or volume creation / `up` will fail.
check_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "Docker not found on PATH. Install Docker Desktop / OrbStack (or compatible) and re-run." >&2
    return 1
  fi
  if ! docker info >/dev/null 2>&1; then
    echo "Docker is installed but not running (or not reachable). Start it and re-run." >&2
    return 1
  fi
}

require_devcontainer() {
  if ! command -v devcontainer >/dev/null 2>&1; then
    echo "The 'devcontainer' CLI is required but not found." >&2
    echo "Install it with: npm install -g @devcontainers/cli  (or: brew install devcontainer)" >&2
    exit 1
  fi
}

# Non-fatal hint for `setup`: the CLI is only needed once you run `up`.
check_devcontainer_cli() {
  if ! command -v devcontainer >/dev/null 2>&1; then
    echo "Note: the 'devcontainer' CLI isn't installed — 'bin/devcontainer up' needs it."
    echo "      Install with: npm install -g @devcontainers/cli  (or: brew install devcontainer)"
  fi
}

# Create each shared external cache volume if absent. Declared `external: true`
# in docker-compose.yml and shared across all worktrees, so they must exist
# before the first `up`. Quiet by default (echoes only on creation); pass any
# arg to also report volumes that already exist.
ensure_shared_volumes() {
  local verbose="${1:-}"
  if [[ ${#SHARED_VOLUMES[@]} -eq 0 ]]; then
    [[ -n "$verbose" ]] && echo "No shared cache volumes configured." || true
    return
  fi
  for v in "${SHARED_VOLUMES[@]}"; do
    if docker volume inspect "$v" >/dev/null 2>&1; then
      [[ -n "$verbose" ]] && echo "Shared volume already exists: $v" || true
    else
      docker volume create "$v" >/dev/null
      echo "Created shared volume: $v"
    fi
  done
}

# Normalize to a valid docker compose project name: lowercase, only [a-z0-9_-],
# must start with an alphanumeric. Compose rejects anything else, and a handle
# passed via --name (e.g. a `feature/Foo` branch handle) can contain slashes or
# uppercase.
sanitize_name() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -c 'a-z0-9_-' '-' \
    | sed -E 's/-+/-/g; s/^[^a-z0-9]+//; s/[^a-z0-9]+$//'
}

derive_name() {
  sanitize_name "$(basename "$ROOT")"
}

port_ok_for_project() {
  # OK if (a) a container in OUR compose project already publishes this port,
  # or (b) nothing on the host is listening on it.
  local port="$1" project="$2"
  if docker ps \
       --filter "publish=$port" \
       --filter "label=com.docker.compose.project=$project" \
       --format '{{.Names}}' | grep -q .; then
    return 0
  fi
  ! lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
}

pick_free_port() {
  local project="$1"
  local p={{DEFAULT_PORT}}
  while ! port_ok_for_project "$p" "$project"; do
    p=$((p + 1))
  done
  echo "$p"
}

# Resolve the absolute host paths the container must mount so git worktrees
# work inside it. A linked worktree's .git is a pointer into the MAIN repo's
# .git/worktrees/<name>, which lives outside this worktree dir and so isn't in
# the /workspace bind — without it, git can't find the object store and commits
# fail. We mount the git common dir (the main repo's .git for a linked worktree,
# or this repo's .git otherwise) and the worktree's own host path, both at their
# real absolute paths, so the pointers resolve. For a normal checkout these are
# harmless self-mounts. Sets GIT_COMMON_DIR and WORKTREE_HOST_DIR.
compute_git_mounts() {
  WORKTREE_HOST_DIR="$ROOT"
  local common
  if common=$(cd "$ROOT" && git rev-parse --git-common-dir 2>/dev/null); then
    case "$common" in
      /*) ;;
      *) common="$ROOT/$common" ;;
    esac
    GIT_COMMON_DIR=$(cd "$common" && pwd)
  else
    # Not a git repo (unusual here) — fall back to a harmless, existing path so
    # compose still gets a valid source and never creates a stray dir.
    GIT_COMMON_DIR="$ROOT"
  fi
}

write_env() {
  local name="$1" port="$2"
  cat > "$ENV_FILE" <<EOF
# Per-worktree devcontainer config. Auto-generated by bin/devcontainer —
# gitignored (machine/worktree-specific). Compose auto-loads this file from the
# compose project dir. Edit and re-run \`bin/devcontainer up\` to apply.
COMPOSE_PROJECT_NAME=$name
PORT=$port
# Absolute host paths mounted into the container at the same path so git
# worktrees resolve (the linked worktree's .git points into the main repo's
# .git, which lives outside /workspace). See docker-compose.yml / README.
GIT_COMMON_DIR=$GIT_COMMON_DIR
WORKTREE_HOST_DIR=$WORKTREE_HOST_DIR
# Commit identity resolved on the host (see resolve_git_identity). Passed into
# the container, where post_install.sh writes it to ~/.gitconfig.local — the
# repo's own .git/config is never touched. Empty when unresolved, or when the
# repo already carries a local identity (git reads that from the bind mount).
GIT_IDENT_NAME=$IDENT_NAME
GIT_IDENT_EMAIL=$IDENT_EMAIL
EOF
  echo "Wrote $ENV_FILE (COMPOSE_PROJECT_NAME=$name, PORT=$port)"
}

# Resolve the commit identity for the CONTAINER without touching the repo's
# .git/config. We read it on the host — where the global git config and any
# GIT_AUTHOR_*/GIT_COMMITTER_* env vars are visible — and pass it via .env into
# the container, where post_install.sh writes it to ~/.gitconfig.local (the
# container's GIT_CONFIG_GLOBAL). That keeps the bind-mounted .git/config
# pristine, which matters especially for worktrees: `git config --local` there
# writes to the SHARED common config, hitting the main checkout and every
# sibling worktree. If the repo already carries a local identity, git reads it
# straight from the bind mount, so we leave that field empty.
#
# Precedence per field: repo-local (leave to git) → global config →
# $GIT_AUTHOR_* → $GIT_COMMITTER_*. Global before env so a transient GIT_AUTHOR_*
# override in the current shell doesn't get baked in when a global exists.
#
# Sets: IDENT_NAME / IDENT_EMAIL — values to inject (empty = covered locally or
#         unresolved); NAME_NOTE / EMAIL_NOTE — human-readable source; and
#         IDENT_MISSING — space-separated fields with no identity anywhere.
resolve_git_identity() {
  IDENT_NAME=""; IDENT_EMAIL=""; NAME_NOTE=""; EMAIL_NOTE=""; IDENT_MISSING=""

  if ! git -C "$ROOT" rev-parse --git-dir >/dev/null 2>&1; then
    NAME_NOTE="(not a git repo — skipped)"; EMAIL_NOTE="$NAME_NOTE"
    return
  fi

  local local_name local_email global_name global_email
  local_name=$(git -C "$ROOT" config --local --get user.name 2>/dev/null || true)
  local_email=$(git -C "$ROOT" config --local --get user.email 2>/dev/null || true)
  global_name=$(git config --global --get user.name 2>/dev/null || true)
  global_email=$(git config --global --get user.email 2>/dev/null || true)

  if   [[ -n "$local_name"             ]]; then NAME_NOTE="already in repo .git/config: $local_name"
  elif [[ -n "$global_name"            ]]; then IDENT_NAME="$global_name";        NAME_NOTE="global git config: $global_name"
  elif [[ -n "${GIT_AUTHOR_NAME:-}"    ]]; then IDENT_NAME="$GIT_AUTHOR_NAME";    NAME_NOTE="\$GIT_AUTHOR_NAME: $GIT_AUTHOR_NAME"
  elif [[ -n "${GIT_COMMITTER_NAME:-}" ]]; then IDENT_NAME="$GIT_COMMITTER_NAME"; NAME_NOTE="\$GIT_COMMITTER_NAME: $GIT_COMMITTER_NAME"
  else IDENT_MISSING+="user.name "; fi

  if   [[ -n "$local_email"             ]]; then EMAIL_NOTE="already in repo .git/config: $local_email"
  elif [[ -n "$global_email"            ]]; then IDENT_EMAIL="$global_email";        EMAIL_NOTE="global git config: $global_email"
  elif [[ -n "${GIT_AUTHOR_EMAIL:-}"    ]]; then IDENT_EMAIL="$GIT_AUTHOR_EMAIL";    EMAIL_NOTE="\$GIT_AUTHOR_EMAIL: $GIT_AUTHOR_EMAIL"
  elif [[ -n "${GIT_COMMITTER_EMAIL:-}" ]]; then IDENT_EMAIL="$GIT_COMMITTER_EMAIL"; EMAIL_NOTE="\$GIT_COMMITTER_EMAIL: $GIT_COMMITTER_EMAIL"
  else IDENT_MISSING+="user.email "; fi
}

# Print what resolve_git_identity found and, if anything's missing, how to fix it.
report_git_identity() {
  [[ -n "$NAME_NOTE"  ]] && echo "  user.name  <- $NAME_NOTE"  || true
  [[ -n "$EMAIL_NOTE" ]] && echo "  user.email <- $EMAIL_NOTE" || true
  if [[ -n "$IDENT_MISSING" ]]; then
    echo
    echo "!! No ${IDENT_MISSING% } found in your global git config, GIT_AUTHOR_*, or GIT_COMMITTER_* env vars."
    echo "   The container needs a commit identity. Set a global one on the host:"
    echo "     git config --global user.name  \"Your Name\""
    echo "     git config --global user.email \"you@example.com\""
    echo "   (or export GIT_AUTHOR_NAME/GIT_AUTHOR_EMAIL), then re-run 'bin/devcontainer up'."
    echo "   Alternatively set it for just this repo with 'git config --local ...'."
    echo "   Until then, commits inside the container fail with 'Author identity unknown'."
  fi
}

cmd_setup() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage; exit 0 ;;
      *) echo "Unknown arg: $1" >&2; exit 1 ;;
    esac
  done

  check_docker
  check_devcontainer_cli

  echo
  echo "Shared toolchain cache volumes:"
  ensure_shared_volumes verbose

  echo
  echo "Commit identity (resolved on the host; applied inside the container on 'up', repo .git/config untouched):"
  resolve_git_identity
  report_git_identity

  cat <<'EOF'

Setup complete. Next:
  bin/devcontainer up      build + start this checkout's stack and run post-create
  devcontainer exec zsh    open a shell in the container
EOF
}

cmd_up() {
  local cli_name="" cli_port="" cli_recreate=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) cli_name="$2"; shift 2 ;;
      --port) cli_port="$2"; shift 2 ;;
      --recreate) cli_recreate=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) echo "Unknown arg: $1" >&2; exit 1 ;;
    esac
  done

  require_devcontainer
  ensure_shared_volumes

  local cur_name="" cur_port=""
  if [[ -f "$ENV_FILE" ]]; then
    cur_name=$(grep -E '^COMPOSE_PROJECT_NAME=' "$ENV_FILE" | head -1 | cut -d= -f2-)
    cur_port=$(grep -E '^PORT=' "$ENV_FILE" | head -1 | cut -d= -f2-)
  fi

  local name port
  name="$(sanitize_name "${cli_name:-${cur_name:-$(derive_name)}}")"
  port="${cli_port:-$cur_port}"

  if [[ -z "$port" ]] || ! port_ok_for_project "$port" "$name"; then
    local new_port
    new_port=$(pick_free_port "$name")
    if [[ -n "$port" && "$port" != "$new_port" ]]; then
      echo "Port $port is in use; switching to $new_port."
    fi
    port="$new_port"
  fi

  # Always (re)write .env: it also carries the absolute git-mount paths, which
  # must be present for compose even when name/port are unchanged, and which
  # move if the worktree is relocated, plus the resolved commit identity.
  compute_git_mounts
  resolve_git_identity
  write_env "$name" "$port"
  echo "Commit identity (written to the container's ~/.gitconfig.local, not the repo's .git/config):"
  report_git_identity

  if [[ -n "$cli_recreate" ]]; then
    devcontainer up --workspace-folder "$ROOT" --remove-existing-container
    print_up_summary "$name" "$port"
    return
  fi

  devcontainer up --workspace-folder "$ROOT"

  # Recover from a stale workspace bind mount. When this git worktree's
  # directory is removed and recreated on the host (git worktree remove/re-add,
  # a reset, etc.), it gets a new inode. Any container already started against
  # the old inode keeps a dangling /workspace mount, but the compose mount spec
  # (source: ..) is textually unchanged, so `devcontainer up` (like `compose
  # up`) sees the container as up-to-date and reuses it. Every exec then fails
  # with `chdir to cwd ("/workspace") ... no such file or directory`.
  #
  # Probe from `/` (the container's default workdir is /workspace, which would
  # itself fail to chdir) and recreate the container if the mount is gone.
  # We recreate via `devcontainer up --remove-existing-container` (not raw
  # compose) so the rebuilt container re-runs postCreateCommand and keeps the
  # locator labels `devcontainer exec` relies on.
  if ! docker compose -f "$COMPOSE_FILE" exec -T -w / app test -d /workspace 2>/dev/null; then
    echo "Workspace mount is stale (worktree likely recreated); recreating the dev container..."
    devcontainer up --workspace-folder "$ROOT" --remove-existing-container
  fi

  print_up_summary "$name" "$port"
}

# Short post-setup message: what just came up and the lifecycle commands.
print_up_summary() {
  local name="$1" port="$2"
  cat <<EOF

Dev container '$name' is up on 127.0.0.1:$port.
  Shell in:   devcontainer exec zsh
  Lifecycle:  bin/devcontainer up      (re)start this checkout's stack
              bin/devcontainer status  show stack status
              bin/devcontainer down    remove it — containers + per-project
                                       volumes (shared caches kept); run before
                                       deleting a worktree dir
EOF
}

cmd_down() {
  local purge_caches=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --caches) purge_caches=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) echo "Unknown arg: $1" >&2; exit 1 ;;
    esac
  done

  local project=""
  if [[ -f "$ENV_FILE" ]]; then
    project=$(grep -E '^COMPOSE_PROJECT_NAME=' "$ENV_FILE" | head -1 | cut -d= -f2-)
  fi

  # Remove this checkout's containers, its default network, and its per-project
  # volumes (history, agent/gh config, DB data). The shared toolchain caches are
  # declared `external: true`, so `down -v` deliberately leaves them intact for
  # other worktrees. --remove-orphans sweeps any leftover services.
  docker compose -f "$COMPOSE_FILE" down -v --remove-orphans

  # Drop the per-worktree env file; the next `up` regenerates it.
  if [[ -f "$ENV_FILE" ]]; then
    rm -f "$ENV_FILE"
    echo "Removed $ENV_FILE"
  fi

  local label="stack"
  [[ -n "$project" ]] && label="stack '$project'" || true
  echo "Tore down $label: containers + per-project volumes removed; shared caches preserved."

  if [[ -n "$purge_caches" ]]; then
    echo "Removing shared toolchain caches (other worktrees of this project will rebuild them)..."
    for v in "${SHARED_VOLUMES[@]}"; do
      if docker volume rm "$v" >/dev/null 2>&1; then
        echo "Removed shared volume: $v"
      else
        echo "Kept shared volume (missing, or still in use by a running container): $v" >&2
      fi
    done
  fi
}

cmd_status() {
  docker compose -f "$COMPOSE_FILE" ps
}

cmd="${1:-}"
shift || true

case "$cmd" in
  setup)        cmd_setup "$@" ;;
  up)           cmd_up "$@" ;;
  down)         cmd_down "$@" ;;
  status)       cmd_status ;;
  -h|--help|"") usage ;;
  *) echo "Unknown command: $cmd" >&2; usage; exit 1 ;;
esac
