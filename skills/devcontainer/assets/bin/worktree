#!/usr/bin/env bash
# Devcontainer lifecycle for the current git worktree.
#
#   bin/worktree up [--name NAME] [--port PORT] [--recreate]
#       Ensure shared volumes exist, write .devcontainer/.env (project name +
#       port), and bring the dev container up via the `devcontainer` CLI. Using
#       the CLI (not raw `docker compose up`) is what runs postCreateCommand
#       (post_install.sh: deps + DB) and stamps the locator labels that
#       `devcontainer exec` needs to find the container. Auto-recreates the
#       container if its /workspace bind mount has gone stale (e.g. the worktree
#       was recreated). Pass --recreate to force-recreate unconditionally.
#
#   bin/worktree down [--caches]
#       Tear down THIS worktree's stack: stop and remove its containers, default
#       network, and per-project volumes (shell history, agent/gh config, DB
#       data), and delete .devcontainer/.env. Shared toolchain caches are
#       preserved for other worktrees. Run this BEFORE deleting the worktree
#       directory (this script lives inside it). Pass --caches to ALSO remove the
#       shared external caches — use only when you're done with the whole project
#       (other worktrees would have to rebuild them).
#
#   bin/worktree status
#       Show stack status.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMPOSE_FILE="${ROOT}/.devcontainer/docker-compose.yml"
ENV_FILE="${ROOT}/.devcontainer/.env"
SHARED_VOLUMES=({{SHARED_VOLUMES}})

usage() {
  sed -n '2,/^set -euo/p' "$0" | sed '$d; s/^# \{0,1\}//'
}

ensure_shared_volumes() {
  for v in "${SHARED_VOLUMES[@]}"; do
    if ! docker volume inspect "$v" >/dev/null 2>&1; then
      docker volume create "$v" >/dev/null
      echo "Created shared volume: $v"
    fi
  done
}

require_devcontainer() {
  if ! command -v devcontainer >/dev/null 2>&1; then
    echo "The 'devcontainer' CLI is required but not found." >&2
    echo "Install it with: npm install -g @devcontainers/cli  (or: brew install devcontainer)" >&2
    exit 1
  fi
}

# Normalize to a valid docker compose project name: lowercase, only [a-z0-9_-],
# must start with an alphanumeric. Compose rejects anything else, and a handle
# passed via --name (e.g. a `feature/Foo` branch handle) can contain slashes or
# uppercase.
sanitize_name() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -c 'a-z0-9_-' '-' \
    | sed -E 's/-+/-/g; s/^[^a-z0-9]+//; s/[^a-z0-9]+$//'
}

derive_name() {
  sanitize_name "$(basename "$ROOT")"
}

port_ok_for_project() {
  # OK if (a) a container in OUR compose project already publishes this port,
  # or (b) nothing on the host is listening on it.
  local port="$1" project="$2"
  if docker ps \
       --filter "publish=$port" \
       --filter "label=com.docker.compose.project=$project" \
       --format '{{.Names}}' | grep -q .; then
    return 0
  fi
  ! lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
}

pick_free_port() {
  local project="$1"
  local p={{DEFAULT_PORT}}
  while ! port_ok_for_project "$p" "$project"; do
    p=$((p + 1))
  done
  echo "$p"
}

# Resolve the absolute host paths the container must mount so git worktrees
# work inside it. A linked worktree's .git is a pointer into the MAIN repo's
# .git/worktrees/<name>, which lives outside this worktree dir and so isn't in
# the /workspace bind — without it, git can't find the object store and commits
# fail. We mount the git common dir (the main repo's .git for a linked worktree,
# or this repo's .git otherwise) and the worktree's own host path, both at their
# real absolute paths, so the pointers resolve. For a normal checkout these are
# harmless self-mounts. Sets GIT_COMMON_DIR and WORKTREE_HOST_DIR.
compute_git_mounts() {
  WORKTREE_HOST_DIR="$ROOT"
  local common
  if common=$(cd "$ROOT" && git rev-parse --git-common-dir 2>/dev/null); then
    case "$common" in
      /*) ;;
      *) common="$ROOT/$common" ;;
    esac
    GIT_COMMON_DIR=$(cd "$common" && pwd)
  else
    # Not a git repo (unusual here) — fall back to a harmless, existing path so
    # compose still gets a valid source and never creates a stray dir.
    GIT_COMMON_DIR="$ROOT"
  fi
}

write_env() {
  local name="$1" port="$2"
  cat > "$ENV_FILE" <<EOF
# Per-worktree devcontainer config. Auto-generated by bin/worktree — gitignored
# (machine/worktree-specific). Compose auto-loads this file from the compose
# project dir. Edit and re-run \`bin/worktree up\` to apply.
COMPOSE_PROJECT_NAME=$name
PORT=$port
# Absolute host paths mounted into the container at the same path so git
# worktrees resolve (the linked worktree's .git points into the main repo's
# .git, which lives outside /workspace). See docker-compose.yml / README.
GIT_COMMON_DIR=$GIT_COMMON_DIR
WORKTREE_HOST_DIR=$WORKTREE_HOST_DIR
EOF
  echo "Wrote $ENV_FILE (COMPOSE_PROJECT_NAME=$name, PORT=$port)"
}

cmd_up() {
  local cli_name="" cli_port="" cli_recreate=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) cli_name="$2"; shift 2 ;;
      --port) cli_port="$2"; shift 2 ;;
      --recreate) cli_recreate=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) echo "Unknown arg: $1" >&2; exit 1 ;;
    esac
  done

  require_devcontainer
  ensure_shared_volumes

  local cur_name="" cur_port=""
  if [[ -f "$ENV_FILE" ]]; then
    cur_name=$(grep -E '^COMPOSE_PROJECT_NAME=' "$ENV_FILE" | head -1 | cut -d= -f2-)
    cur_port=$(grep -E '^PORT=' "$ENV_FILE" | head -1 | cut -d= -f2-)
  fi

  local name port
  name="$(sanitize_name "${cli_name:-${cur_name:-$(derive_name)}}")"
  port="${cli_port:-$cur_port}"

  if [[ -z "$port" ]] || ! port_ok_for_project "$port" "$name"; then
    local new_port
    new_port=$(pick_free_port "$name")
    if [[ -n "$port" && "$port" != "$new_port" ]]; then
      echo "Port $port is in use; switching to $new_port."
    fi
    port="$new_port"
  fi

  # Always (re)write .env: it also carries the absolute git-mount paths, which
  # must be present for compose even when name/port are unchanged, and which
  # move if the worktree is relocated.
  compute_git_mounts
  write_env "$name" "$port"

  if [[ -n "$cli_recreate" ]]; then
    devcontainer up --workspace-folder "$ROOT" --remove-existing-container
    print_up_summary "$name" "$port"
    return
  fi

  devcontainer up --workspace-folder "$ROOT"

  # Recover from a stale workspace bind mount. When this git worktree's
  # directory is removed and recreated on the host (git worktree remove/re-add,
  # a reset, etc.), it gets a new inode. Any container already started against
  # the old inode keeps a dangling /workspace mount, but the compose mount spec
  # (source: ..) is textually unchanged, so `devcontainer up` (like `compose
  # up`) sees the container as up-to-date and reuses it. Every exec then fails
  # with `chdir to cwd ("/workspace") ... no such file or directory`.
  #
  # Probe from `/` (the container's default workdir is /workspace, which would
  # itself fail to chdir) and recreate the container if the mount is gone.
  # We recreate via `devcontainer up --remove-existing-container` (not raw
  # compose) so the rebuilt container re-runs postCreateCommand and keeps the
  # locator labels `devcontainer exec` relies on.
  if ! docker compose -f "$COMPOSE_FILE" exec -T -w / app test -d /workspace 2>/dev/null; then
    echo "Workspace mount is stale (worktree likely recreated); recreating the dev container..."
    devcontainer up --workspace-folder "$ROOT" --remove-existing-container
  fi

  print_up_summary "$name" "$port"
}

# Short post-setup message: what just came up and the lifecycle commands.
print_up_summary() {
  local name="$1" port="$2"
  cat <<EOF

Dev container '$name' is up on 127.0.0.1:$port.
  Shell in:   devcontainer exec zsh
  Lifecycle:  bin/worktree up      (re)start this worktree's stack
              bin/worktree status  show stack status
              bin/worktree down    remove it — containers + per-project volumes
                                   (shared caches kept); run before deleting the
                                   worktree dir
EOF
}

cmd_down() {
  local purge_caches=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --caches) purge_caches=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) echo "Unknown arg: $1" >&2; exit 1 ;;
    esac
  done

  local project=""
  if [[ -f "$ENV_FILE" ]]; then
    project=$(grep -E '^COMPOSE_PROJECT_NAME=' "$ENV_FILE" | head -1 | cut -d= -f2-)
  fi

  # Remove this worktree's containers, its default network, and its per-project
  # volumes (history, agent/gh config, DB data). The shared toolchain caches are
  # declared `external: true`, so `down -v` deliberately leaves them intact for
  # other worktrees. --remove-orphans sweeps any leftover services.
  docker compose -f "$COMPOSE_FILE" down -v --remove-orphans

  # Drop the per-worktree env file; the next `up` regenerates it.
  if [[ -f "$ENV_FILE" ]]; then
    rm -f "$ENV_FILE"
    echo "Removed $ENV_FILE"
  fi

  local label="stack"
  [[ -n "$project" ]] && label="stack '$project'"
  echo "Tore down $label: containers + per-project volumes removed; shared caches preserved."

  if [[ -n "$purge_caches" ]]; then
    echo "Removing shared toolchain caches (other worktrees of this project will rebuild them)..."
    for v in "${SHARED_VOLUMES[@]}"; do
      if docker volume rm "$v" >/dev/null 2>&1; then
        echo "Removed shared volume: $v"
      else
        echo "Kept shared volume (missing, or still in use by a running container): $v" >&2
      fi
    done
  fi
}

cmd_status() {
  docker compose -f "$COMPOSE_FILE" ps
}

cmd="${1:-}"
shift || true

case "$cmd" in
  up)     cmd_up "$@" ;;
  down)   cmd_down "$@" ;;
  status) cmd_status ;;
  -h|--help|"") usage ;;
  *) echo "Unknown command: $cmd" >&2; usage; exit 1 ;;
esac
